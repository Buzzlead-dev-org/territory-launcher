# Required — Anthropic for site analysis, intel synthesis, and copy generation
# Get one: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Required — Exa for Reddit + competitor research
# Get one: https://exa.ai
EXA_API_KEY=xxx

# Required — AI Ark for prospect sourcing + email verification
# Contact AI Ark for a key: https://ai-ark.com
AI_ARK_API_KEY=xxx

# Optional — Jina Reader (higher rate limits + faster lane on the site scrape)
# Anonymous works fine, but a key helps for heavy use.
# Get one: https://jina.ai
JINA_API_KEY=

# Optional — webhook URL for AI Ark email-finder. AI Ark requires the field
# but you don't need to consume the webhook (we poll /statistics + /inquiries).
# Leave unset to use a no-op default.
AIARK_EMAIL_FINDER_WEBHOOK=
